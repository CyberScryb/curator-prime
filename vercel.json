{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/health", "destination": "/api" },
    { "source": "/api/analyze-item", "destination": "/api" },
    { "source": "/api/analyze-live", "destination": "/api" },
    { "source": "/api/ask", "destination": "/api" },
    { "source": "/api/market-analysis", "destination": "/api" },
    { "source": "/api/generate-image", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "{prompts/**,api/**}"
    }
  }
}
